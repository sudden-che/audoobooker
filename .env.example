# Скопируйте в .env и заполните значения
# cp .env.example .env

# Режим запуска: web | bot | both
MODE=web

# Telegram-бот (обязательно для режимов bot и both)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Параметры синтеза
TTS_ENGINE=qwen3
WEB_TTS_ENGINE=qwen3
VOICE=ru-RU-SvetlanaNeural
SPEED=+18%
CHUNK_SIZE=10000
MAX_CONCURRENT_TASKS=8
MAX_CONCURRENT_REQUESTS=2
MAX_CONCURRENT_UPDATES=4
FORWARD_GROUP_DEBOUNCE_SECONDS=5.0
FFMPEG_PATH=ffmpeg
MERGE_CHUNKS=true
MAX_TEXT_FROM_MESSAGE=50000

# Параметры Silero (temporarily disabled)
# SILERO_LANGUAGE=ru
# SILERO_MODEL_ID=v5_ru
# SILERO_SPEAKER=baya
# SILERO_SAMPLE_RATE=48000
# SILERO_PUT_ACCENT=true
# SILERO_PUT_YO=true
# DEVICE=cpu

# Параметры Qwen3-TTS (CustomVoice)
QWEN3_MODEL_ID=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN3_SPEAKER=Serena
QWEN3_LANGUAGE=Russian
QWEN3_INSTRUCT="Говори более низким, злым, возбужденным женским голосом, спокойный темп, грудной резонанс, без пискливости"
QWEN3_DEVICE=cpu

# Веб-сервер
WEB_HOST=0.0.0.0
WEB_PORT=8000
